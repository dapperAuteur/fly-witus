# Fly.WitUS environment variables
# Pull live values: `vercel env pull` (after `vercel link`)
# Generate secrets: `openssl rand -base64 32`

# App identity
NEXT_PUBLIC_APP_URL=https://fly.witus.online
NEXT_PUBLIC_APP_NAME="Fly WitUS"
ADMIN_EMAIL=bam@awews.com

# Database — Neon (auto-provisioned by Vercel Marketplace integration)
DATABASE_URL=postgres://user:pass@host-pooled/REPLACE_WITH_NEON_DB_NAME?sslmode=require
DATABASE_URL_UNPOOLED=postgres://user:pass@host-direct/REPLACE_WITH_NEON_DB_NAME?sslmode=require

# Better Auth (magic link only — no OAuth, no passwords)
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-output
BETTER_AUTH_URL=http://localhost:3000

# Mailgun (transactional email)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.witus.online
MAILGUN_REGION=us
EMAIL_FROM="Fly WitUS <noreply@fly.witus.online>"
ADMIN_NOTIFY_EMAIL=bam@awews.com

# Stripe (card payments — monthly / annual / lifetime)
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID_MONTHLY=price_replace_me
STRIPE_PRICE_ID_ANNUAL=price_replace_me
STRIPE_PRICE_ID_LIFETIME=price_replace_me

# CashApp (manual activation flow — no API)
NEXT_PUBLIC_CASHAPP_USERNAME=$Centenarian
NEXT_PUBLIC_CASHAPP_QR_PATH=/images/cashapp-qr.jpg

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=devdash54321
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=fly_witus_unsigned

# Vercel Cron (24h CashApp pending reminder)
CRON_SECRET=replace-with-openssl-rand-base64-32-output